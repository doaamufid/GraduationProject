<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.GraduationProject" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorOnPrimary">@color/text_main</item>
        <item name="materialButtonStyle">@style/OutlinedButtonStyle</item>
        <item name="android:statusBarColor">@color/bg</item>
    </style>

    <style name="OutlinedButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">#2C6E9E</item>
        <item name="backgroundTint">#FFFFFF</item>
        <item name="strokeColor">#A8CDE0</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>


    <style name="Theme.SurvivalBox" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/grad_top</item>
        <item name="colorAccent">@color/primary_light</item>
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="android:statusBarColor">@color/grad_top</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    <style name="ThemeOverlay.FutureSelf.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/FutureSelf.BottomSheetStyle</item>
    </style>
    <style name="FutureSelf.BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="Theme.FutureSelf.Dialog" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:layoutDirection">rtl</item>
        <item name="android:textDirection">rtl</item>
        <item name="android:windowIsFloating">true</item>
    </style>
</resources>
    <style name="Theme.graduationproject" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:layoutDirection">rtl</item>
        <item name="android:textDirection">rtl</item>
        <item name="android:textColorHint">@color/text_soft</item>
    </style>

    <style name="ThemeOverlay.SurvivalBox.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/SurvivalBox.BottomSheetStyle</item>
    </style>

    <style name="SurvivalBox.BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <!-- Full-screen style used by the crisis-mode DialogFragment -->
    <style name="Theme.SurvivalBox.FullScreenDialog" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:layoutDirection">rtl</item>
        <item name="android:textDirection">rtl</item>
        <item name="android:statusBarColor">@color/grad_top</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
    </style>
    <style name="ThemeOverlay.DailyHabits.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/DailyHabits.BottomSheetStyle</item>
    </style>
    <style name="DailyHabits.BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>
</resources>

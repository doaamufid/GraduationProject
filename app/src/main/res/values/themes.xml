<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.GraduationProject" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorPrimaryVariant">#FFFFFF</item>
        <item name="android:colorBackground">#E8F4FC</item>
        <item name="colorOnPrimary">#1A3A5C</item>
        <item name="materialButtonStyle">@style/OutlinedButtonStyle</item>
        <item name="android:statusBarColor">#E8F4FC</item>
    </style>

    <style name="OutlinedButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">#2C6E9E</item>
        <item name="backgroundTint">#FFFFFF</item>
        <item name="strokeColor">#A8CDE0</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1F1FF"
    tools:context=".bottomNavFragments.HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/imageLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/imgWaveBottom"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="fitXY"
            android:src="@drawable/img_1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="150dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layoutDirection="rtl">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:lineSpacingExtra="4dp"
                android:text="صباح الخير بيان كيف تشعر الآن؟\nأنا هنا معك 🌊"
                android:textColor="#2D5B7B"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvMoodTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="مزاج اليوم - TODAY'S MOOD"
                android:textColor="#6A8CA3"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/tvGreeting"
                app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

            <LinearLayout
                android:id="@+id/layoutEmojis"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/white_rounded_card"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="10dp"
                android:paddingHorizontal="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvMoodTitle">

                <ImageView
                    android:id="@+id/emoji1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/emoji_selector"
                    android:src="@drawable/avatar" />

                <ImageView
                    android:id="@+id/emoji2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/emoji_selector"
                    android:src="@drawable/sad" />

                <ImageView
                    android:id="@+id/emoji3"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/emoji_selector"
                    android:src="@drawable/smiley" />

                <ImageView
                    android:id="@+id/emoji4"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/emoji_selector"
                    android:src="@drawable/bored" />

                <ImageView
                    android:id="@+id/emoji5"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/emoji_selector"
                    android:src="@drawable/happiness" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvActions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutEmojis"
                tools:itemCount="2"
                tools:listitem="@layout/item_home_action" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeatures"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvActions"
                app:spanCount="3"
                tools:itemCount="9"
                tools:listitem="@layout/item_home_feature" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
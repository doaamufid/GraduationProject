<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    xmlns:tools1="http://schemas.android.com/tools"
    android:id="@+id/layoutMainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF6FC"
    android:layoutDirection="rtl"
    tools1:context=".ArticlesActivity">

    <!-- 1. خلفية الهيدر الموحد الجديد باللون الأبيض وبطول 56dp -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 2. زر الرجوع في أقصى اليمين متناسق تماماً مع نظام RTL -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/outline_arrow_forward_24"
        android:padding="4dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/headerBackground"
        app:layout_constraintBottom_toBottomOf="@+id/headerBackground" />

    <!-- 3. عنوان الصفحة "مساحة الهدوء" في منتصف الهيدر تماماً بالمقاس واللون الموحد -->
    <TextView
        android:id="@+id/tvToolbarTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مساحة الهدوء"
        android:textColor="#2D5B7B"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@+id/headerBackground"
        app:layout_constraintBottom_toBottomOf="@+id/headerBackground"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- محتوى الصفحة يبدأ الآن تحت الهيدر الجديد مباشرة -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollViewLibrary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerBackground"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/layoutScrollContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/tvArticlesSectionTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المقالات • ARTICLES"
                android:textColor="#3A74B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/tvLibraryMainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مكتبة المقالات الذكية"
                android:textColor="#1F3A60"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvLibrarySubTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مقترحة حسب حالتك"
                android:textColor="#3A74B8"
                android:textSize="14sp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="2dp" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:background="@android:drawable/editbox_background_normal"
                android:hint="ابحث في المكتبة..."
                android:paddingHorizontal="16dp"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:id="@+id/horizontalScrollCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:id="@+id/layoutCategoriesContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnFilterAll"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="الكل"
                        android:backgroundTint="#3A74B8"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnFilterSleep"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="النوم"
                        android:backgroundTint="#1A3A74B8"
                        android:textColor="#3A74B8"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnFilterBreathing"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="التنفس"
                        android:backgroundTint="#1A3A74B8"
                        android:textColor="#3A74B8"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnFilterCbt"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:text="CBT"
                        android:backgroundTint="#1A3A74B8"
                        android:textColor="#3A74B8"
                        android:textSize="13sp"
                        android:layout_marginEnd="8dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvRecommendedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مقترحة لك الآن • RECOMMENDED"
                android:textColor="#7F8C8D"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardFeaturedArticle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A3A74B8">

                <LinearLayout
                    android:id="@+id/layoutFeaturedInner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/viewFeaturedIndicator"
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#3A74B8" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutFeaturedContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvFeaturedTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="مقال مختار • FEATURED"
                            android:textColor="#3A74B8"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvFeaturedTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="كيف تتعاملين مع الحزن بدون قمعه؟"
                            android:textColor="#1F3A60"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            android:gravity="start"
                            app:layout_constraintTop_toBottomOf="@id/tvFeaturedTag"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"/>

                        <TextView
                            android:id="@+id/tvFeaturedLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ابدئي القراءة ←"
                            android:textColor="#3A74B8"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/tvFeaturedTitle"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvThisWeekLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="هذا الأسبوع • THIS WEEK"
                android:textColor="#7F8C8D"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvArticles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_article_card" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
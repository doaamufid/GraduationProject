<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutMainSurvivalRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:layoutDirection="rtl">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/outline_arrow_forward_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="صندوق الطوارئ"
            android:textColor="#3A74B8"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollViewSurvival"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/cardOpenBoxContainer">

        <LinearLayout
            android:id="@+id/layoutScrollContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvSurvivalSectionTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صندوق النجاة • SAFE SPACE"
                android:textColor="#3A74B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvSurvivalMainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صندوق النجاة النفسي"
                android:textColor="#1F3A60"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvSurvivalSubTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="افتحه في لحظات الضيق الشديد"
                android:textColor="#3A74B8"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardStaticSpace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A3A74B8">

                <LinearLayout
                    android:id="@+id/layoutSpaceCardInner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/viewSpaceIndicator"
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#3A74B8" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutSpaceCardContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvSpaceTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="مساحتك • YOUR SPACE"
                            android:textColor="#3A74B8"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintRight_toRightOf="parent"/>

                        <TextView
                            android:id="@+id/tvSpaceTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="هذا المكان جمعتِه لنفسكِ"
                            android:textColor="#1F3A60"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"
                            app:layout_constraintTop_toBottomOf="@id/tvSpaceTag"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toRightOf="parent"/>

                        <TextView
                            android:id="@+id/tvSpaceDescription"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="كل ما يريحك ويذكرك بأنكِ أمان - في مكان واحد"
                            android:textColor="#557597"
                            android:textSize="13sp"
                            android:layout_marginTop="6dp"
                            app:layout_constraintTop_toBottomOf="@id/tvSpaceTitle"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintRight_toRightOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSurvivalItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardOpenBoxContainer"
        android:layout_width="match_parent"
        android:layout_height="84dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#4F80B9"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btnOpenBoxCustom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardHeartCircle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginRight="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivHeartCircleIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/outline_favorite_24"
                    app:tint="#FF5252" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/layoutMainBtnTextContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvMainBtnText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="افتح الصندوق الآن"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMainBtnSubText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عرض كل ما يريحك في ثانية واحدة"
                    android:textColor="#D9E6F2"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:background="@drawable/bg_sheet_top_rounded"
    android:padding="20dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="start"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_close"
            android:contentDescription="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/add_love_title"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="14sp"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/btnSourceSelf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="@string/tag_self"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="@drawable/bg_pill_selector"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSourceOther"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/tag_other"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="@drawable/bg_pill_selector"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <EditText
        android:id="@+id/edtText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minLines="4"
        android:gravity="top|end"
        android:background="@drawable/bg_input"
        android:padding="14dp"
        android:hint="@string/love_text_hint"
        android:textColor="@color/text_white"
        android:textColorHint="@color/text_soft"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"
        android:inputType="textMultiLine"/>

    <TextView
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill_primary"
        android:text="@string/save_message"
        android:textColor="@color/text_white"
        android:textStyle="bold"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="14dp"
        android:alpha="0.4"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===================== TOP BAR ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="10dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_arrow_right"
                android:padding="9dp"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/top_bar_label"
                android:textColor="@color/text_soft"
                android:textSize="11sp"
                android:gravity="left"/>
        </LinearLayout>

        <!-- ===================== SCROLLABLE CONTENT ===================== -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fillViewport="true">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <!-- In-progress group -->
                <LinearLayout
                    android:id="@+id/groupInProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Progress header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/progress_title"
                            android:textColor="@color/text_main"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:letterSpacing="0.15"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/progress_sub"
                            android:textColor="@color/text_soft"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <!-- Progress bar -->
                    <FrameLayout
                        android:id="@+id/progressTrack"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:background="@drawable/bg_progress_track"
                        android:layout_marginBottom="6dp">

                        <View
                            android:id="@+id/progressFill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_progress_fill"/>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvStepCounter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="left"
                        android:textColor="@color/text_soft"
                        android:textSize="10sp"
                        android:layout_marginBottom="24dp"
                        tools:text="خطوة ١ من ٥"/>

                    <!-- Current sense step (fades in on change) -->
                    <LinearLayout
                        android:id="@+id/groupStep"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tvEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="36sp"
                            android:layout_marginBottom="4dp"
                            tools:text="👀"/>

                        <TextView
                            android:id="@+id/tvTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_soft"
                            android:textSize="10sp"
                            tools:text="SEE · تشاهد"/>

                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="6dp"
                            android:textColor="@color/text_main"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            tools:text="٥ أشياء تراها"/>

                        <TextView
                            android:id="@+id/tvQuestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/text_soft"
                            android:textSize="12sp"
                            android:layout_marginBottom="20dp"
                            tools:text="انظري حواليك والمسي بعينك ٥ أشياء"/>

                        <!-- Tap counter squares, built programmatically -->
                        <LinearLayout
                            android:id="@+id/llTapCounter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvTappedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_soft"
                            android:textSize="10sp"
                            android:layout_marginBottom="20dp"
                            tools:text="٠/٥ — بس اضغطي كل ما لاحظتي شي"/>
                    </LinearLayout>

                    <!-- Optional note toggle -->
                    <LinearLayout
                        android:id="@+id/btnToggleNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginBottom="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivChevron"
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_chevron_down"
                            android:layout_marginStart="6dp"
                            android:contentDescription="@null"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_note_toggle"
                            android:textColor="@color/text_soft"
                            android:textStyle="bold"
                            android:textSize="11sp"/>
                    </LinearLayout>

                    <EditText
                        android:id="@+id/edtNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_note_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:hint="@string/note_hint"
                        android:textColor="@color/text_main"
                        android:textColorHint="@color/text_soft"
                        android:textSize="13sp"
                        android:gravity="end"
                        android:singleLine="true"
                        android:layout_marginBottom="20dp"
                        android:visibility="gone"/>

                    <!-- Breathing reminder -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_reminder_card"
                        android:text="@string/breathing_reminder"
                        android:textColor="@color/text_soft"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Next / finish button -->
                    <LinearLayout
                        android:id="@+id/btnNext"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_pill_dark"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvNextLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/surface"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            tools:text="التالي"/>

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_arrow_left"
                            android:contentDescription="@null"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Done group -->
                <LinearLayout
                    android:id="@+id/groupDone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/emoji_leaf"
                        android:textSize="46sp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/done_title"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvDoneSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_soft"
                        android:textSize="12sp"
                        android:layout_marginBottom="24dp"
                        tools:text="لاحظت ١٥ تفاصيل حواليك — بأقل من دقيقة"/>

                    <TextView
                        android:id="@+id/btnAnother"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_another_exercise"
                        android:textColor="@color/surface"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:background="@drawable/bg_pill_dark_round"
                        android:paddingStart="32dp"
                        android:paddingEnd="32dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

            </FrameLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_cancel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:padding="4dp"
        android:text="إلغاء ←"
        android:textColor="#8B6F4D"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_mic_status"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_kids_bubble_primary"
        android:gravity="center"
        android:text="🎙️"
        android:textSize="32sp" />

    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="٠:٠٠"
        android:textColor="#4B2D24"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="قول اللي حاسس فيه، وأنا بنسمعك 🧸"
        android:textColor="#8B6F4D"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/btn_finish_recording"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:background="#21B573"
        android:gravity="center"
        android:text="خلصت! ✅"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
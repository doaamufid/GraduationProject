<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/white_rounded_card"
    android:paddingVertical="16dp"
    android:paddingHorizontal="8dp">

    <ImageView
        android:id="@+id/ivFeatureIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="9dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/home1"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/tvFeatureTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/card_title"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivFeatureIcon"
        tools:text="مرئيات"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/tvFeatureSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/card_subtitle"
        android:textSize="9sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFeatureTitle"
        tools:text="VIDEOS"
        xmlns:tools="http://schemas.android.com/tools" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FB"
    android:layoutDirection="rtl">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_margin="20dp"
        android:padding="4dp"
        android:src="@drawable/outline_arrow_forward_24"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#3A74B8" />

    <LinearLayout
        android:id="@+id/layoutTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="start"
        android:orientation="vertical"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginRight="24dp">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مرحباً في مساحتك"
            android:textColor="#557597"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvMainHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="هنا فقط\nأنتَ"
            android:textColor="#1F3A60"
            android:textSize="36sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="0.9"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="آمن • هادئ"
            android:textColor="#3A74B8"
            android:textSize="16sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvMoodThisWeekLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مزاجك هذا الأسبوع"
            android:textColor="#3A74B8"
            android:textSize="12sp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="65dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="30dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutChart"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="8dp">

                <ProgressBar
                    android:id="@+id/donutProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:indeterminate="false"
                    android:max="7"
                    android:progress="5"
                    android:progressDrawable="@drawable/custom_donut_progress"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvProgressData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="٥\nمن ٧ أيام"
                    android:textColor="#1F3A60"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/donutProgress"
                    app:layout_constraintLeft_toLeftOf="@id/donutProgress"
                    app:layout_constraintRight_toRightOf="@id/donutProgress"
                    app:layout_constraintTop_toTopOf="@id/donutProgress" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tvStreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                android:background="@android:color/white"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="✦ ٧ أيام متتالية"
                android:textColor="#1D9E75"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginTop="20dp"
                android:text="اليوم"
                android:textColor="#557597"
                android:textSize="13sp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="2"
                android:rowCount="2">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDream"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="#E6EEF8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="إعادة صياغة الكوابيس" android:textColor="#1F3A60" android:textStyle="bold" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="اكتب نهاية جديدة" android:textColor="#557597" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardJournal"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="#E6EEF8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="يوميات مشفرة" android:textColor="#1F3A60" android:textStyle="bold" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="خاصة بك فقط" android:textColor="#557597" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBalance"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="#E6EEF8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="تمرين التوازن" android:textColor="#1F3A60" android:textStyle="bold" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="بحر بشيء يطمئنني" android:textColor="#557597" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTreeMemory"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="#E6EEF8"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="شجرة ذاكرتي" android:textColor="#1F3A60" android:textStyle="bold" android:textSize="12sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="اجمع ما يستحق البقاء" android:textColor="#557597" android:textSize="11sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#E6EEF8"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <TextView
                        android:id="@+id/tvQuoteText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="اليوم كان صعباً لكنني\nشعرت بشيء أجمل بعد..."
                        android:textColor="#1F3A60"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnReadAllWeek"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_below="@id/tvQuoteText"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#378ADD"
                        android:text="اقرأ الأسبوع كله ←"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardBalanceExercise"
                android:layout_width="match_parent"
                android:layout_height="85dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#E6EEF8"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تمرين التوازن الآن"
                        android:textColor="#1F3A60"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="٥ دقائق للهدنة"
                        android:textColor="#557597"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الرئيسية" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navMood" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_compass" app:tint="#378ADD" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المزاج" android:textColor="#378ADD" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navReminders" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_popup_reminder" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="أذكار" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="أنا" android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
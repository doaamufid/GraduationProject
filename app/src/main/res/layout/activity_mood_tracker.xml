<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:layoutDirection="rtl">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/outline_arrow_forward_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="متابعة المزاج"
            android:textColor="#3A74B8"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/tvMoodSubTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مزاجي • MOOD"
                android:textColor="#3A74B8"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvMoodMainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مزاجي هذا الأسبوع"
                android:textColor="#1F3A60"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvMoodInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="٧ أيام • محفوظ على جهازك"
                android:textColor="#557597"
                android:textSize="14sp"
                android:layout_marginTop="2dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvChartTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="توزيع المشاعر • EMOTIONS"
                        android:textColor="#557597"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_gravity="start" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/moodBarChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLowMood"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E6EEF8">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="start">
                        <TextView android:id="@+id/tvLowLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="انخفاض" android:textColor="#557597" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvLowDay" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الثلاثاء" android:textColor="#1F3A60" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/tvLowDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="والجمعة أضعف" android:textColor="#557597" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvLowCountTag" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="٣ مرات" android:textColor="#A07855" android:background="#FCECDD" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textSize="11sp" android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardHighGratitude"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#E6EEF8">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="start">
                        <TextView android:id="@+id/tvHighLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الأكثر" android:textColor="#557597" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvHighAction" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="امتنان" android:textColor="#1F3A60" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:id="@+id/tvHighSource" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="أذكار الصباح" android:textColor="#557597" android:textSize="12sp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="14dp">
                            <ProgressBar
                                android:id="@+id/progressGratitude"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="69"
                                android:progressTint="#3A74B8"
                                android:progressBackgroundTint="#D0DBE9"/>
                            <TextView
                                android:id="@+id/tvProgressValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="69%"
                                android:textColor="#3A74B8"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E6EEF8">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvTimelineTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="المسار اليومي • TIMELINE"
                        android:textColor="#557597"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintRight_toRightOf="parent"/>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/layoutTimelineRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/tvTimelineTag">

                        <View
                            android:id="@+id/viewTimelineLine"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="#D0DBE9"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <View
                            android:id="@+id/dot1"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@android:color/holo_blue_light"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintHorizontal_bias="0.1"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <View
                            android:id="@+id/dot2"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@android:color/holo_blue_dark"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintHorizontal_bias="0.4"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <View
                            android:id="@+id/dot3"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@android:color/holo_orange_light"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintHorizontal_bias="0.7"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>

                        <View
                            android:id="@+id/dotActive"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@android:color/holo_blue_dark"
                            app:layout_constraintLeft_toLeftOf="parent"
                            app:layout_constraintHorizontal_bias="0.9"
                            app:layout_constraintRight_toRightOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardAiInsights"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E6EEF8">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvAiTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ملاحظة الأسبوع • AI"
                        android:textColor="#557597"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintRight_toRightOf="parent"/>

                    <TextView
                        android:id="@+id/tvAiContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="لاحظتُ أن مزاجكِ يكون أفضل في المساء. تمرين التنفس قبل النوم قد يساعد ← جرّبيه الليلة"
                        android:textColor="#1F3A60"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAiTag"/>

                    <Button
                        android:id="@+id/btnBreathingExercise"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="تمرين التنفس ←"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#4F80B9"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:layout_constraintTop_toBottomOf="@id/tvAiContent"
                        app:layout_constraintLeft_toLeftOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMoodLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E6EEF8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvLogTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="سجل الآن • LOG"
                        android:textColor="#557597"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_gravity="start"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnCalm"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:text="هادئ ✓"
                                android:textColor="#FFFFFF"
                                android:backgroundTint="#4F80B9"
                                android:textSize="13sp"
                                android:layout_marginEnd="6dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"/>

                            <Button
                                android:id="@+id/btnAnxious"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:text="قلق"
                                android:textColor="#1F3A60"
                                android:backgroundTint="#D0DBE9"
                                android:textSize="13sp"
                                android:layout_marginEnd="6dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"/>

                            <Button
                                android:id="@+id/btnTired"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:text="تعب"
                                android:textColor="#1F3A60"
                                android:backgroundTint="#D0DBE9"
                                android:textSize="13sp"
                                android:layout_marginEnd="6dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"/>

                            <Button
                                android:id="@+id/btnHappy"
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:text="سعيد"
                                android:textColor="#1F3A60"
                                android:backgroundTint="#D0DBE9"
                                android:textSize="13sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"/>

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
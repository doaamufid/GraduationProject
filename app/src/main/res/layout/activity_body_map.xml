<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7FAFC"
    android:layoutDirection="rtl"
    tools:context=".BodyMapActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="رجوع"
            android:src="@drawable/outline_arrow_forward_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="المشاعر في جسدك"
            android:textColor="#3A6898"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvGuideText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="أين تشعر بالتوتر؟ حدد المنطقة بالضغط عليها أو من القائمة تحت"
                android:textColor="#7F8C8D"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp" />

            <!-- حاوية خارطة الجسد بعد تكبيرها وإضافة مناطق النقر الذكية -->
            <!-- حاوية خارطة الجسد مع الدوائر المرئية والخطوط المتقطعة مثل الفيجما -->
            <!-- حاوية خارطة الجسد الكاملة المستوردة كصورة واحدة من الفيجما -->
            <!-- حاوية خارطة الجسد - تم زيادة الارتفاع لـ 360dp لمنع التصاق البطاقات وإعطائها مساحة مريحة -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutBodyContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp">

                <!-- مجسم الجسد -->
                <ImageView
                    android:id="@+id/imgBody"
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/body"
                    android:clickable="false"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.80"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- ================= مناطق النقر الشفافة الموزعة بدقة ================= -->

                <!-- نقرة الرأس والرقبة -->
                <View
                    android:id="@+id/dotHead"
                    android:layout_width="45dp"
                    android:layout_height="40dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintBottom_toBottomOf="@id/imgBody"
                    app:layout_constraintEnd_toEndOf="@id/imgBody"
                    app:layout_constraintStart_toStartOf="@id/imgBody"
                    app:layout_constraintTop_toTopOf="@id/imgBody"
                    app:layout_constraintVertical_bias="0.06" />

                <!-- نقرة الأكتاف -->
                <View
                    android:id="@+id/dotShoulders"
                    android:layout_width="85dp"
                    android:layout_height="28dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintBottom_toBottomOf="@id/imgBody"
                    app:layout_constraintEnd_toEndOf="@id/imgBody"
                    app:layout_constraintStart_toStartOf="@id/imgBody"
                    app:layout_constraintTop_toTopOf="@id/imgBody"
                    app:layout_constraintVertical_bias="0.24" />

                <!-- نقرة الصدر -->
                <View
                    android:id="@+id/dotChest"
                    android:layout_width="55dp"
                    android:layout_height="35dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintBottom_toBottomOf="@id/imgBody"
                    app:layout_constraintEnd_toEndOf="@id/imgBody"
                    app:layout_constraintStart_toStartOf="@id/imgBody"
                    app:layout_constraintTop_toTopOf="@id/imgBody"
                    app:layout_constraintVertical_bias="0.44" />

                <!-- نقرة المعدة -->
                <View
                    android:id="@+id/dotStomach"
                    android:layout_width="55dp"
                    android:layout_height="35dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintBottom_toBottomOf="@id/imgBody"
                    app:layout_constraintEnd_toEndOf="@id/imgBody"
                    app:layout_constraintStart_toStartOf="@id/imgBody"
                    app:layout_constraintTop_toTopOf="@id/imgBody"
                    app:layout_constraintVertical_bias="0.66" />

                <!-- ================= البطاقات التفاعلية الجانبية (يسار) ================= -->

                <!-- بطاقة الرأس والرقبة -->
                <LinearLayout
                    android:id="@+id/cardLeftHead"
                    android:layout_width="105dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_suggestion_btn"
                    android:backgroundTint="#FFF9E7"
                    android:padding="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/dotHead"
                    app:layout_constraintBottom_toBottomOf="@id/dotHead">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الرأس والرقبة"
                        android:textColor="#B7950B"
                        android:textStyle="bold"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="صداع • توتر"
                        android:textColor="#7F8C8D"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- بطاقة الأكتاف -->
                <LinearLayout
                    android:id="@+id/cardLeftShoulders"
                    android:layout_width="105dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_suggestion_btn"
                    android:backgroundTint="#EBF5FB"
                    android:padding="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/dotShoulders"
                    app:layout_constraintBottom_toBottomOf="@id/dotShoulders">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الأكتاف"
                        android:textColor="#2980B9"
                        android:textStyle="bold"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ثقل • تصلب"
                        android:textColor="#7F8C8D"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- بطاقة الصدر -->
                <LinearLayout
                    android:id="@+id/cardLeftChest"
                    android:layout_width="105dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_suggestion_btn"
                    android:backgroundTint="#FDEDEC"
                    android:padding="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/dotChest"
                    app:layout_constraintBottom_toBottomOf="@id/dotChest">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الصدر"
                        android:textColor="#CB4335"
                        android:textStyle="bold"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ضيق • خفقان"
                        android:textColor="#7F8C8D"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- بطاقة المعدة -->
                <LinearLayout
                    android:id="@+id/cardLeftStomach"
                    android:layout_width="105dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_suggestion_btn"
                    android:backgroundTint="#EAECEE"
                    android:padding="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/dotStomach"
                    app:layout_constraintBottom_toBottomOf="@id/dotStomach">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="المعدة"
                        android:textColor="#5D6D7E"
                        android:textStyle="bold"
                        android:textSize="11sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="غثيان • قلق"
                        android:textColor="#7F8C8D"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- ================= الخطوط المتقطعة الرابطة ================= -->

                <!-- خط الرأس -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layerType="software"
                    android:background="@drawable/dashed_line"
                    app:layout_constraintBottom_toBottomOf="@id/dotHead"
                    app:layout_constraintEnd_toStartOf="@id/dotHead"
                    app:layout_constraintStart_toEndOf="@id/cardLeftHead"
                    app:layout_constraintTop_toTopOf="@id/dotHead" />

                <!-- خط الأكتاف -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layerType="software"
                    android:background="@drawable/dashed_line"
                    app:layout_constraintBottom_toBottomOf="@id/dotShoulders"
                    app:layout_constraintEnd_toStartOf="@id/dotShoulders"
                    app:layout_constraintStart_toEndOf="@id/cardLeftShoulders"
                    app:layout_constraintTop_toTopOf="@id/dotShoulders" />

                <!-- خط الصدر -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layerType="software"
                    android:background="@drawable/dashed_line"
                    app:layout_constraintBottom_toBottomOf="@id/dotChest"
                    app:layout_constraintEnd_toStartOf="@id/dotChest"
                    app:layout_constraintStart_toEndOf="@id/cardLeftChest"
                    app:layout_constraintTop_toTopOf="@id/dotChest" />

                <!-- خط المعدة -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layerType="software"
                    android:background="@drawable/dashed_line"
                    app:layout_constraintBottom_toBottomOf="@id/dotStomach"
                    app:layout_constraintEnd_toStartOf="@id/dotStomach"
                    app:layout_constraintStart_toEndOf="@id/cardLeftStomach"
                    app:layout_constraintTop_toTopOf="@id/dotStomach" />

            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerExercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_exercise_panel" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
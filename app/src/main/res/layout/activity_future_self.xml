<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===================== TOP BAR ===================== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="14dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="start"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_arrow_right"
                android:padding="9dp"
                android:contentDescription="@null"/>
        </FrameLayout>

        <!-- ===================== HEADER ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="0dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رسالة إلى نفسي"
                android:textColor="@color/text_main"
                android:textStyle="bold"
                android:textSize="32sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="رسالتك اليوم تسبح نحو يومك القادم"
                android:textColor="@color/text_soft"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- ===================== MAIN CONTENT ===================== -->
        <FrameLayout
            android:id="@+id/timelineContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.example.graduationproject.widget.CurvedTimelineView
                android:id="@+id/curvedTimelineView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Message Preview Bubble (Will be positioned programmatically near the end) -->
            <FrameLayout
                android:id="@+id/cardTodayPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/white_rounded_card"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvTodayPreviewText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_soft"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="top|start"
                    android:layout_marginStart="-3dp"
                    android:layout_marginTop="-3dp"
                    android:background="@drawable/bg_icon_pink"
                    android:padding="3dp"
                    android:src="@drawable/heartbeat_solid"
                    app:tint="@color/accent"
                    android:contentDescription="@null"/>
            </FrameLayout>

            <!-- Message nodes and labels added programmatically -->

        </FrameLayout>

        <!-- ===================== FOOTER ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="20dp"
            android:elevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="رسائل سابقة"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textAlignment="viewStart"/>

                <TextView
                    android:id="@+id/btnViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عرض الكل"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvFooterPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="لا رسائل سابقة بعد"
                    android:textColor="@color/text_soft"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:text="وصلت"
                        android:textColor="@color/text_soft"
                        android:textSize="11sp" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/heartbeat_solid"
                        app:tint="@color/accent_soft"
                        android:contentDescription="@null"/>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Hidden views to maintain code compatibility -->
    <ImageButton android:id="@+id/btnShowAll" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />
    <ImageButton android:id="@+id/btnCompose" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />
    <View android:id="@+id/fabPulseRing" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />
    <View android:id="@+id/groupEmpty" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />

</FrameLayout>

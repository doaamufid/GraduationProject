<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===================== TOP BAR ===================== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp">

            <ImageButton
                android:id="@+id/btnShowAll"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_list"
                android:padding="9dp"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="9:41"
                android:textColor="@color/text_main"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </RelativeLayout>

        <!-- ===================== HEADER ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رسالة إلى نفسي"
                android:textColor="@color/text_main"
                android:textStyle="bold"
                android:textSize="32sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="رسالتك اليوم تسبح نحو يومك القادم"
                android:textColor="@color/text_soft"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- ===================== SCROLLABLE TIMELINE ===================== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:overScrollMode="never">

                <FrameLayout
                    android:id="@+id/timelineContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="40dp"
                    android:paddingBottom="100dp">

                    <com.example.graduationproject.widget.CurvedTimelineView
                        android:id="@+id/curvedTimelineView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <!-- Message node buttons are added programmatically here -->

                </FrameLayout>
            </ScrollView>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/groupEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_mail_large_soft"
                    android:layout_marginBottom="12dp"
                    android:contentDescription="@null"
                    android:alpha="0.3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ابدأ برحلتك.. اكتب رسالة لنفسك بالمستقبل"
                    android:textColor="@color/text_soft"
                    android:textSize="14sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Floating compose button -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="24dp">

                <View
                    android:id="@+id/fabPulseRing"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_fab_ring"
                    android:visibility="visible"/>

                <ImageButton
                    android:id="@+id/btnCompose"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_fab"
                    android:src="@drawable/ic_plus"
                    android:padding="22dp"
                    android:elevation="8dp"
                    android:contentDescription="@null"/>
            </FrameLayout>

        </FrameLayout>

        <!-- ===================== FOOTER: PREVIOUS MESSAGES ===================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="رسائل سابقة"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <LinearLayout
                    android:id="@+id/btnViewAllContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/btnViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="عرض الكل"
                        android:textColor="@color/accent"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_list"
                        android:tint="@color/accent"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvFooterPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_soft"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:maxLines="2"
                android:ellipsize="end"
                android:clickable="true"
                android:focusable="true"
                android:text="اليوم كان صعباً لكنك تجاوزته، وأنت أقوى مما تتخيل الآن. احتفظ به..." />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>

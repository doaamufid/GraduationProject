<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    android:layoutDirection="rtl">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/viewIconBg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_outer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:id="@+id/imgNotificationIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/outline_favorite_24"
            app:layout_constraintStart_toStartOf="@id/viewIconBg"
            app:layout_constraintEnd_toEndOf="@id/viewIconBg"
            app:layout_constraintTop_toTopOf="@id/viewIconBg"
            app:layout_constraintBottom_toBottomOf="@id/viewIconBg" />

        <TextView
            android:id="@+id/tvNotificationTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="وقت تمرين التنفس"
            android:textColor="#2D5B7B"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/viewIconBg"
            app:layout_constraintEnd_toStartOf="@id/tvNotificationTime"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvNotificationBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="خصص 3 دقائق لنفسك الآن"
            android:textColor="#99AAB5"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvNotificationTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNotificationTitle" />

        <TextView
            android:id="@+id/tvNotificationTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="قبل 5 ساعات"
            android:textColor="#99AAB5"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvNotificationTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
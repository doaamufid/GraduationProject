<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    tools:context=".SplashSelectActivity">

    <ImageView
        android:id="@+id/cloud_left"
        android:layout_width="110dp"
        android:layout_height="50dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="60dp"
        android:src="@drawable/cloud"
        android:alpha="0.9"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/baseline_arrow_back_24"
        android:contentDescription="@null"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/cloud_right"
        android:layout_width="130dp"
        android:layout_height="55dp"
        android:contentDescription="@null"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/cloud"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circle_large"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/circle_outer"
        android:alpha="0.2"
        android:layout_marginTop="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/circle_mid"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:background="@drawable/circle_outer"
        android:alpha="0.25"
        app:layout_constraintStart_toStartOf="@id/circle_large"
        app:layout_constraintEnd_toEndOf="@id/circle_large"
        app:layout_constraintTop_toTopOf="@id/circle_large"
        app:layout_constraintBottom_toBottomOf="@id/circle_large" />

    <View
        android:id="@+id/circle_small"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/ic_circle_bg"
        app:layout_constraintStart_toStartOf="@id/circle_large"
        app:layout_constraintEnd_toEndOf="@id/circle_large"
        app:layout_constraintTop_toTopOf="@id/circle_large"
        app:layout_constraintBottom_toBottomOf="@id/circle_large" />

    <ImageView
        android:id="@+id/ic_drop"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_drop"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="@id/circle_large"
        app:layout_constraintEnd_toEndOf="@id/circle_large"
        app:layout_constraintTop_toTopOf="@id/circle_large"
        app:layout_constraintBottom_toBottomOf="@id/circle_large" />

    <TextView
        android:id="@+id/text_salam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="سلام"
        android:textSize="22sp"
        android:textColor="#1A3A5C"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/circle_large" />

    <TextView
        android:id="@+id/text_question"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="لمن هذا المكان؟"
        android:textSize="24sp"
        android:textColor="#1A3A5C"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_salam" />

    <TextView
        android:id="@+id/text_sub_question"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="اختر الفئة المناسبة لك"
        android:textSize="14sp"
        android:textColor="#5A88B8"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_question" />

    <EditText
        android:id="@+id/et_name"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/input_bg"
        android:hint="@string/name_hint"
        android:textColorHint="#94B2CB"
        android:inputType="textPersonName"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#1A3A5C"
        android:textSize="14sp"
        android:textDirection="rtl"
        android:gravity="center_vertical|right"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_sub_question" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btn_adults_card"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/bg_identity_card"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        android:padding="18dp"
        app:layout_constraintTop_toBottomOf="@id/et_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/iconAdultContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_adult_icon"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_drop"
                android:contentDescription="@null"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_adults_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="للبالغين"
            android:textColor="#17395A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="end"
            android:textAlignment="viewEnd"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iconAdultContainer"
            android:layout_marginStart="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="مساحة هادئة للتأمل والدعم النفسي"
            android:textColor="#6F8AA8"
            android:textSize="15sp"
            android:gravity="end"
            android:textAlignment="viewEnd"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toBottomOf="@id/tv_adults_title"
            app:layout_constraintStart_toEndOf="@id/iconAdultContainer"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btn_kids_card"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/bg_identity_card_kids"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        android:padding="18dp"
        app:layout_constraintTop_toBottomOf="@id/btn_adults_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/iconKidsContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_kids_icon"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/sun"
                android:contentDescription="@null"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_kids_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="للأطفال"
            android:textColor="#A76000"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="end"
            android:textAlignment="viewEnd"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iconKidsContainer"
            android:layout_marginStart="16dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="عالم ممتع وآمن لك!"
            android:textColor="#C3872C"
            android:textSize="15sp"
            android:gravity="end"
            android:textAlignment="viewEnd"
            android:layout_marginTop="5dp"
            app:layout_constraintTop_toBottomOf="@id/tv_kids_title"
            app:layout_constraintStart_toEndOf="@id/iconKidsContainer"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout></androidx.constraintlayout.widget.ConstraintLayout>
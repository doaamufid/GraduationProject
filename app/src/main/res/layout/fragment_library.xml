<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <include layout="@layout/view_top_bar"/>

            <!-- Search bar (visual only, matches the original's non-functional input) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_bar"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginBottom="12dp">

                <EditText
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/search_hint"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_soft"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:paddingStart="8dp"
                    android:paddingEnd="0dp"
                    android:minHeight="0dp"/>

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="@null"/>
            </LinearLayout>

            <!-- Category chips -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:clipToPadding="false"/>

            <!-- Featured hero card -->
            <LinearLayout
                android:id="@+id/groupFeatured"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_featured_card"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include
                        android:id="@+id/includeFeaturedArt"
                        layout="@layout/view_article_art"/>

                    <TextView
                        android:id="@+id/tvFeaturedBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="12dp"
                        android:background="@drawable/bg_featured_badge"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="@string/featured_badge"
                        android:textSize="9sp"
                        android:textStyle="bold"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/tvFeaturedTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_neutral"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:textColor="@color/text_soft"
                            android:textSize="9sp"
                            android:layout_marginStart="8dp"
                            tools:text="CBT"/>

                        <TextView
                            android:id="@+id/tvFeaturedTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_soft"
                            android:textSize="10sp"
                            android:drawableStart="@drawable/ic_clock"
                            android:drawablePadding="4dp"
                            tools:text="٥ دقائق"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvFeaturedTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:lineSpacingMultiplier="1.15"
                        android:layout_marginBottom="4dp"
                        tools:text="كيف تتعاملين مع الحزن بدون قمعه؟"/>

                    <TextView
                        android:id="@+id/tvFeaturedAuthor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:textColor="@color/text_soft"
                        android:textSize="10sp"
                        tools:text="د. نورا العلي"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/text_soft"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginBottom="12dp"
                tools:text="هذا الأسبوع"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerArticles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="rtl"
    android:padding="14dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_video"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:id="@+id/thumbnailContainer"
        android:layout_width="100dp"
        android:layout_height="70dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true">

        <View
            android:id="@+id/thumbGradient"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_thumb_gradient" />

        <ImageView
            android:id="@+id/ivTypeIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play"
            android:alpha="0.9"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="6dp"
            android:background="@drawable/bg_duration_badge"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textColor="@color/white"
            android:textSize="9sp"
            tools:text="١٢:٣٤" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/textContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/thumbnailContainer"
        android:layout_toStartOf="@id/ivFavorite"
        android:layout_centerVertical="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="start">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textColor="@color/primary_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            tools:text="كيف تتعامل مع القلق؟" />

        <TextView
            android:id="@+id/tvSrc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textColor="@color/text_soft"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            tools:text="منهج الصحة النفسية" />

        <TextView
            android:id="@+id/tvTypePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_type_pill"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textColor="@color/text_soft"
            android:textSize="10sp"
            tools:text="فيديو" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivFavorite"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:padding="8dp"
        android:background="@drawable/bg_fav_circle"
        android:src="@drawable/ic_bookmark_outline"
        android:contentDescription="@null"
        android:clickable="true"
        android:focusable="true" />

</RelativeLayout>

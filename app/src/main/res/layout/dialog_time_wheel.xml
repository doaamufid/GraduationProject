<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:background="@drawable/bg_sheet_top_rounded"
    android:padding="20dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="start"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_close"
            android:contentDescription="@null"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/choose_time"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            android:textSize="14sp"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_time_col_bg"
        android:padding="8dp">

        <ScrollView
            android:id="@+id/scrollHours"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_weight="1"
            android:scrollbars="none"/>

        <ScrollView
            android:id="@+id/scrollMinutes"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_weight="1"
            android:scrollbars="none"/>

        <ScrollView
            android:id="@+id/scrollAmPm"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_weight="1"
            android:scrollbars="none"/>
    </LinearLayout>

    <TextView
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill_primary"
        android:text="@string/time_done"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="15dp"
        android:layout_marginTop="16dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>

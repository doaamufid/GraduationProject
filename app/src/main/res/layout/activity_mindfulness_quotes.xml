<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/quotes_background"
    android:padding="24dp"
    tools:context=".MindfulnessQuotesActivity">

    <!-- أيقونة علامات الاقتباس كخلفية جمالية لطيفة -->
    <TextView
        android:id="@+id/tvQuoteIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="“"
        android:textColor="#3A70A4"
        android:textSize="90sp"
        android:textStyle="bold"
        android:alpha="0.15"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/tvQuote"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvQuote"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="مرحباً بك في مساحتك الآمنة..."
        android:textColor="#1A3A5C"
        android:textSize="22sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/btnSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ادخل مساحتك "
        android:textColor="#5A88B8"
        android:textSize="15sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
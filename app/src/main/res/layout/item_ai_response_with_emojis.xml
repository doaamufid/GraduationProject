<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutUserMsg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="right"
    android:paddingVertical="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#378ADD"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/tvAiMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="260dp"
                android:text="&quot;بعد كل ليلة ثقيلة فجرٌ ينتظر. أنتِ لستِ وحدكِ - سلام هنا معكِ.&quot;"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvUserMsgTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="left"
                android:layout_marginTop="4dp"
                android:text="9:40 ص ✓✓"
                android:textColor="#D0E3F7"
                android:textSize="10sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@android:color/white"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="كيف أشعرتك؟"
            android:textColor="#557597"
            android:textSize="11sp"
            android:layout_marginLeft="8dp"/>

        <ImageButton
            android:id="@+id/btnEmoji_Angry"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:text="😡"
            android:textSize="14sp"/>

        <ImageButton
            android:id="@+id/btnEmoji_SadSmile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:text="😢"
            android:textSize="14sp"
            android:layout_marginHorizontal="4dp"/>

        <ImageButton
            android:id="@+id/btnEmoji_TearSmile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@android:color/transparent"
            android:text="😌"
            android:textSize="14sp"/>
    </LinearLayout>
</LinearLayout>
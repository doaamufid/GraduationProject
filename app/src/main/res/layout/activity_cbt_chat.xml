<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/layoutMainChatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FB"
    android:layoutDirection="rtl">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F4F8FB"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivProfileSpinner"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@android:drawable/progress_horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutUserStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="right"
            android:layout_marginRight="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toLeftOf="@id/ivProfileSpinner"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvChatUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سلام"
                android:textColor="#1F3A60"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvChatUserStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مساحة الهدوء • ONLINE"
                android:textColor="#1D9E75"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/outline_arrow_forward_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#1F3A60" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvMessageTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@android:color/white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:text="رسالة شخصية من سلام"
        android:textColor="#557597"
        android:textSize="12sp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCbtChatMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/layoutQuickReplies"
        app:layout_constraintTop_toBottomOf="@id/tvMessageTag"
        tools:listitem="@layout/item_cbt_ai_suggestion" />

    <LinearLayout
        android:id="@+id/layoutQuickReplies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toTopOf="@id/layoutInputBar">

        <Button
            android:id="@+id/btnQuickReplyTalk"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="أحتاج للتحدث"
            android:textSize="11sp"
            android:textColor="#1F3A60"
            android:backgroundTint="#E6EEF8"
            android:layout_marginHorizontal="4dp"/>

        <Button
            android:id="@+id/btnQuickReplyFine"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="أنا بخير اليوم"
            android:textSize="11sp"
            android:textColor="#1F3A60"
            android:backgroundTint="#E6EEF8"
            android:layout_marginHorizontal="4dp"/>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutInputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivVoiceInput"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_btn_speak_now"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#378ADD" />

        <EditText
            android:id="@+id/etMessageInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:background="@android:color/transparent"
            android:hint="اكتب شيئاً..."
            android:inputType="textShortMessage"
            android:paddingHorizontal="12dp"
            android:textColor="#1F3A60"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="@id/ivSendMessage"
            app:layout_constraintRight_toLeftOf="@id/ivVoiceInput"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivSendMessage"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_send"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#378ADD" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
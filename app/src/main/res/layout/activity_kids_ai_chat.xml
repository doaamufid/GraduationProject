<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF1E6"
    android:layoutDirection="rtl"
    android:textDirection="rtl"
    tools:context=".Kids.KidsAiChatActivity">

    <!-- Circle Back Button Top End -->
    <TextView
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_kids_bubble_circle"
        android:gravity="center"
        android:text="←"
        android:textColor="#8B6F4D"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bear Avatar Head -->
    <TextView
        android:id="@+id/tv_bear_avatar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="🐻"
        android:textSize="72sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back" />

    <!-- Badge Header (Rounded Rectangle shape) -->
    <TextView
        android:id="@+id/tv_nour_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_kids_mood_card"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:text="أنا هنا أسمعك 💙"
        android:textColor="#3D291F"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_bear_avatar" />

    <!-- ==================== STATE 1: CHILD INPUT STATE ==================== -->
    <LinearLayout
        android:id="@+id/group_input_state"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/btn_talk_nour"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_nour_badge">

        <TextView
            android:id="@+id/tv_question_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="كيف حالك الحين؟"
            android:textColor="#3D291F"
            android:textSize="19sp"
            android:textStyle="bold" />

        <!-- Mood Grid (6 Unique Emoji Cards) -->
        <GridLayout
            android:id="@+id/grid_moods"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:columnCount="3"
            android:rowCount="2">

            <!-- 1. خايف -->
            <LinearLayout
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_kids_mood_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😨" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="خايف" android:textColor="#4B2D24" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- 2. حزين -->
            <LinearLayout
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_kids_mood_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😢" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="حزين" android:textColor="#4B2D24" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- 3. زعلان -->
            <LinearLayout
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_kids_mood_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😡" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="زعلان" android:textColor="#4B2D24" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- 4. مش عارف -->
            <LinearLayout
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_kids_mood_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😕" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="مش عارف" android:textColor="#4B2D24" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- 5. تعبان -->
            <LinearLayout
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_kids_mood_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😫" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="تعبان" android:textColor="#4B2D24" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- 6. مبسوط -->
            <LinearLayout
                android:layout_width="96dp"
                android:layout_height="76dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_kids_mood_card"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊" android:textSize="26sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="مبسوط" android:textColor="#4B2D24" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>
        </GridLayout>

        <!-- Dynamic Container 1: Voice Mode -->
        <LinearLayout
            android:id="@+id/layout_voice_input"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:id="@+id/btn_record_mic"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_kids_bubble_primary"
                android:gravity="center"
                android:text="🎙️"
                android:textSize="32sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="اضغط واحكيلي"
                android:textColor="#F47C2B"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_switch_to_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:padding="6dp"
                android:text="أو اكتب"
                android:textColor="#8B6F4D"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dynamic Container 2: Text Mode -->
        <LinearLayout
            android:id="@+id/layout_text_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:visibility="gone">
            <EditText
                android:id="@+id/edt_child_message"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_kids_mood_card"
                android:gravity="top|start"
                android:hint="اكتب اللي حاسس فيه هنا..."
                android:inputType="textMultiLine|textLongMessage"
                android:padding="14dp"
                android:textColor="#3D291F"
                android:textColorHint="#B2A195"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_switch_to_voice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:padding="6dp"
                android:text="أو سجل صوتك"
                android:textColor="#8B6F4D"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Wide Button: حكيت نور! ⭐ -->
    <TextView
        android:id="@+id/btn_talk_nour"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginHorizontal="28dp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_kids_bubble_primary"
        android:gravity="center"
        android:text="حكيت نور! ⭐"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ==================== STATE 2: LOADING STATE ==================== -->
    <LinearLayout
        android:id="@+id/group_loading_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_bear_avatar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نور يستمع لك..."
            android:textColor="#8B6F4D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:indeterminateTint="#F47C2B" />
    </LinearLayout>

    <!-- ==================== STATE 3: AI RESPONSE STATE (Hidden initially) ==================== -->
    <LinearLayout
        android:id="@+id/group_response_state"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_bear_avatar">

        <!-- Speech Bubble Card -->
        <TextView
            android:id="@+id/tv_ai_response_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_kids_mood_card"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:paddingVertical="18dp"
            android:text="تعبك مسموع، خذ راحتك شوي."
            android:textColor="#3D291F"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Listen Button Pill -->
        <TextView
            android:id="@+id/btn_listen_voice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#D8EBE4"
            android:gravity="center"
            android:paddingHorizontal="22dp"
            android:paddingVertical="10dp"
            android:text="اسمع رد نور 🔊"
            android:textColor="#598F7A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Title Question -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="وش تحب تسوي الحين؟"
            android:textColor="#8B6F4D"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Option 1: خذ نفس معي -->
        <TextView
            android:id="@+id/btn_action_breath"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="#FDE8D7"
            android:gravity="center"
            android:text="خذ نفس معي 🫧"
            android:textColor="#E07026"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Option 2: ارسم كيف حاسس -->
        <TextView
            android:id="@+id/btn_action_draw"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="#E3EFE9"
            android:gravity="center"
            android:text="ارسم كيف حاسس 🎨"
            android:textColor="#427A65"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Option 3: خلص، أنا أحسن الحين -->
        <TextView
            android:id="@+id/btn_action_better"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_kids_mood_card"
            android:gravity="center"
            android:text="خلص، أنا أحسن الحين 💛"
            android:textColor="#8B6F4D"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp">

        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_circle_dashed" />

        <LinearLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_send_message"
            android:gravity="center"
            android:orientation="vertical"
            android:elevation="4dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/heartbeat_solid"
                app:tint="@android:color/white"
                android:layout_marginBottom="4dp"
                android:contentDescription="@null"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أرسل\nالرسالة"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:gravity="center"
                android:lineSpacingMultiplier="0.9"/>
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="سنعود إليك بعد شهر من اليوم"
        android:textColor="@color/text_soft"
        android:textSize="13sp" />

</LinearLayout>

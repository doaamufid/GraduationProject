<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Reading-progress strip (simplified: sits just above the top bar,
             equivalent in effect to the original's absolute top-0 overlay) -->
        <FrameLayout
            android:id="@+id/progressTrack"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/bg_progress_track">

            <View
                android:id="@+id/progressFill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_progress_fill"/>
        </FrameLayout>

        <include layout="@layout/view_top_bar"/>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="32dp">

                <!-- Hero banner -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <include
                        android:id="@+id/includeHeroArt"
                        layout="@layout/view_article_art"/>

                    <ImageButton
                        android:id="@+id/btnSave"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="top|left"
                        android:layout_margin="12dp"
                        android:background="@drawable/bg_bookmark_overlay"
                        android:src="@drawable/ic_bookmark_outline"
                        android:padding="8dp"
                        android:contentDescription="@null"/>
                </FrameLayout>

                <!-- Tag + time row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_neutral"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:textColor="@color/text_soft"
                        android:textSize="9sp"
                        android:layout_marginStart="8dp"
                        tools:text="CBT"/>

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_soft"
                        android:textSize="10sp"
                        android:drawableStart="@drawable/ic_clock"
                        android:drawablePadding="4dp"
                        tools:text="٥ دقائق"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:lineSpacingMultiplier="1.15"
                    android:layout_marginBottom="4dp"
                    tools:text="كيف تتعاملين مع الحزن بدون قمعه؟"/>

                <TextView
                    android:id="@+id/tvAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_soft"
                    android:textSize="11sp"
                    android:layout_marginBottom="20dp"
                    tools:text="بقلم د. نورا العلي"/>

                <!-- Body paragraphs, added programmatically -->
                <LinearLayout
                    android:id="@+id/llBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp"/>

                <!-- Related exercise -->
                <LinearLayout
                    android:id="@+id/groupRelatedExercise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_related_exercise_card"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp">

                        <View
                            android:id="@+id/relatedIconBox"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_related_icon_box"/>

                        <ImageView
                            android:id="@+id/ivRelatedIcon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            tools:src="@drawable/ic_sparkles"
                            android:contentDescription="@null"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/try_it_label"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:textSize="9sp"/>

                        <TextView
                            android:id="@+id/tvRelatedLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_main"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            tools:text="ذاكرة الامتنان"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Feedback row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/feedback_question"
                        android:textColor="@color/text_soft"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="end"/>

                    <ImageButton
                        android:id="@+id/btnThumbDown"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_reaction_neutral"
                        android:src="@drawable/ic_thumb_down_outline"
                        android:padding="13dp"
                        android:layout_marginStart="8dp"
                        android:contentDescription="@null"/>

                    <ImageButton
                        android:id="@+id/btnThumbUp"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_reaction_neutral"
                        android:src="@drawable/ic_thumb_up_outline"
                        android:padding="13dp"
                        android:contentDescription="@null"/>
                </LinearLayout>

                <!-- Dislike reasons panel -->
                <LinearLayout
                    android:id="@+id/groupReasons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_reason_panel"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/reason_prompt"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="end"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.flexbox.FlexboxLayout
                        android:id="@+id/flexReasons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:flexWrap="wrap"
                        app:justifyContent="flex_end"/>
                </LinearLayout>

                <!-- Why suggested -->
                <LinearLayout
                    android:id="@+id/btnWhy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_why_panel"
                    android:padding="14dp"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/why_suggested"
                        android:textColor="@color/sage"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:gravity="end"/>

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_sparkles_sage"
                        android:contentDescription="@null"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvWhyReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/text_soft"
                    android:textSize="11sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    tools:text="لأن مزاجك مال للحزن مرتين هالأسبوع"/>

                <!-- Suggestions -->
                <TextView
                    android:id="@+id/tvSuggestionsLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="@string/continue_reading"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/llSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Toast host: bottom-aligned overlay above everything -->
    <FrameLayout
        android:id="@+id/toastHost"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</FrameLayout>

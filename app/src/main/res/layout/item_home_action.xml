<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/white_rounded_card"
    android:padding="16dp">

    <ImageView xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/ivActionIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/home1" />

    <TextView xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/tvActionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/card_title"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvActionSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivActionIcon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="لحظة هدوء - One-Click Calm" />

    <TextView xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/tvActionSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/card_subtitle"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/tvActionTitle"
        app:layout_constraintStart_toStartOf="@id/tvActionTitle"
        app:layout_constraintTop_toBottomOf="@id/tvActionTitle"
        tools:text="تنفس، استرخِ، توازن" />


</androidx.constraintlayout.widget.ConstraintLayout>
